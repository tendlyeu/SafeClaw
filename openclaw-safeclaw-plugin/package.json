{
  "name": "openclaw-safeclaw-plugin",
  "version": "2.0.1",
  "description": "SafeClaw Neurosymbolic Governance plugin for OpenClaw — validates AI agent actions against OWL ontologies and SHACL constraints",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "safeclaw-plugin": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.8",
      "minGatewayVersion": "2026.6.8"
    },
    "build": {
      "openclawVersion": "2026.6.8",
      "pluginSdkVersion": "2026.6.8"
    }
  },
  "files": [
    "dist/",
    "types/",
    "openclaw.plugin.json",
    "index.ts",
    "cli.tsx",
    "tui/",
    "SKILL.md",
    "README.md",
    "policies/"
  ],
  "keywords": [
    "openclaw",
    "safeclaw",
    "governance",
    "neurosymbolic",
    "ai-safety",
    "owl",
    "shacl",
    "ontology",
    "ai-agent",
    "tool-validation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tendlyeu/SafeClaw.git",
    "directory": "openclaw-safeclaw-plugin"
  },
  "homepage": "https://safeclaw.eu",
  "bugs": {
    "url": "https://github.com/tendlyeu/SafeClaw/issues"
  },
  "author": "Tendly EU",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.8"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  }
}
